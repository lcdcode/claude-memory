# claude-memory local config (Termux)

# PostgreSQL (peer/local trust on Termux)
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DATABASE=claude_memory
PG_USER=
PG_PASSWORD=

# Ollama (localhost only — SSRF guard in server.py)
OLLAMA_HOST=http://127.0.0.1:11434
EMBEDDING_MODEL=nomic-embed-text

# Memory ownership
USER_ID=

# ACT-R cognitive scoring
USE_ACTR_SCORING=true
ACTR_DECAY_D=0.5
ACTR_WEIGHT_W=11.0
ACTR_NOISE_SIGMA=1.2
ACTR_THRESHOLD_TAU=-2.0
ACTR_SPREADING_S=2.0
ACTR_USE_SPREADING=true
ACTR_USE_NOISE=true
ACTR_PREFETCH_LIMIT=50
